---
import Navbar from "../components/common/Navbar.astro";
import Footer from "../components/common/Footer.astro";

const { title } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>

  <body>
    <Navbar />

    <main>
      <slot />
    </main>

    <Footer />
  </body>
</html>
