---
import MainLayout from "../layouts/MainLayout.astro";

import Hero from "../components/common/Hero.astro";
import Topics from "../components/webinar/Topics.astro";

import "../styles/global.css";
---

<MainLayout title="Webinars">
  <Hero>
    <Fragment slot="title">
      Webinars Gratuitos de Ciberseguridad <span>Blockchain</span>
    </Fragment>

    <Fragment slot="description">
      Aprende a identificar vulnerabilidades críticas en Smart Contracts, protocolos DeFi y aplicaciones Web3 de la mano de especialistas en auditoría y seguridad blockchain.
    </Fragment>

    <Fragment slot="actions">
      <a href="#contact" class="btn">Reserva Mi Lugar</a>
    </Fragment>
  </Hero>

  <Topics />
</MainLayout>
