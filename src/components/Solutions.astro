---
import "../styles/solutions.css";
---

<section id="solutions" class="solutions">
  <h2 class="section-title">Nuestras Soluciones</h2>
  <div class="solutions-grid">
    <div class="card">
      <div class="card-icon">🛡️</div>
      <h3>Auditoría de Smart Contracts</h3>
      <p>
        Analizamos tu código antes del despliegue para neutralizar fallas de
        reentrada y manipulación de oráculos, garantizando la inmutabilidad de
        tus protocolos.
      </p>
    </div>

    <div class="card">
      <div class="card-icon">🕵️‍♂️</div>
      <h3>Defensa DeFi Integral</h3>
      <p>
        Combinamos ciberseguridad avanzada, OSINT y análisis forense digital en
        la nube para proteger tu ecosistema financiero contra amenazas
        complejas.
      </p>
    </div>

    <div class="card">
      <div class="card-icon">⛓️</div>
      <h3>Inmutabilidad Segura</h3>
      <p>
        Validamos tus activos digitales con el respaldo de consultores
        independientes para prevenir pérdidas de fondos catastróficas en
        entornos Web3.
      </p>
    </div>
  </div>
</section>
