---
import "../../styles/topics.css";
---

<section id="audience" class="topics">
  <h2 class="section-title">¿Para quién está dirigido?</h2>

  <div class="cards-grid">
    <div class="card">
      <h3>Desarrolladores Web3</h3>
      <p>Que quieran crear contratos más seguros.</p>
    </div>

    <div class="card">
      <h3>Startups Blockchain</h3>
      <p>Que necesiten reducir riesgos antes del lanzamiento.</p>
    </div>

    <div class="card">
      <h3>Equipos DeFi</h3>
      <p>Interesados en auditorías y mejores prácticas.</p>
    </div>

    <div class="card">
      <h3>Analistas de Seguridad</h3>
      <p>Que busquen especializarse en Web3.</p>
    </div>
  </div>
</section>
